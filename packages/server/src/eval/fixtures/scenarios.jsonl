# Main eval dataset for the temporal recall-quality harness (JSONL, one Scenario per line).
# Lines starting with # or // are ignored. See ../types.ts for the exact schema.
# Coverage: single-hop factual, multi-hop, temporal supersession (with stale-leak probes), distractors.
{"id":"laptop-model","description":"Single-hop factual recall: one memory holds the answer.","events":[{"ts":"2026-01-08T14:20:00Z","content":"My primary work laptop is a 16-inch MacBook Pro (M3 Max, 64GB RAM), asset tag LT-4471.","tags":["hardware","laptop"]},{"ts":"2026-01-09T10:00:00Z","content":"Set up a Thunderbolt dock with dual 4K monitors at my desk.","tags":["hardware","desk-setup"]}],"queries":[{"ts":"2026-04-01T00:00:00Z","query":"what is my work laptop","expectContains":["MacBook Pro","M3 Max"],"hops":1},{"ts":"2026-04-01T00:00:00Z","query":"what is my laptop asset tag","expectContains":["LT-4471"],"hops":1}]}
{"id":"prod-db-choice","description":"Single-hop factual recall of a stable architecture decision plus a distractor caching note.","events":[{"ts":"2026-02-01T12:00:00Z","content":"We decided to use PostgreSQL 16 as the primary datastore for the billing service.","tags":["decision","database","billing"]},{"ts":"2026-02-03T09:30:00Z","content":"The billing service uses Redis for caching invoice line-item lookups, not as a primary store.","tags":["cache","billing"]}],"queries":[{"ts":"2026-06-01T00:00:00Z","query":"what is the primary database for billing","expectContains":["PostgreSQL"],"expectAbsent":["Redis"],"hops":1},{"ts":"2026-06-01T00:00:00Z","query":"what does billing use for caching","expectContains":["Redis"],"hops":1}]}
{"id":"api-key-location","description":"Single-hop recall of an operational detail (where a secret lives).","events":[{"ts":"2026-01-22T16:45:00Z","content":"The Stripe live API key is stored in 1Password under the 'Payments Prod' vault, item 'stripe-live-sk'.","tags":["secrets","stripe","ops"]}],"queries":[{"ts":"2026-05-10T00:00:00Z","query":"where is the Stripe production API key kept","expectContains":["1Password","Payments Prod"],"hops":1}]}
{"id":"person-to-project","description":"Multi-hop: link a person to their project, then the project to its deadline.","events":[{"ts":"2026-01-05T08:00:00Z","content":"Priya Nair owns the Atlas migration project.","tags":["people","atlas"]},{"ts":"2026-01-06T08:00:00Z","content":"The Atlas migration project must be finished before the Q3 board review on 2026-08-15.","tags":["atlas","roadmap"]}],"queries":[{"ts":"2026-03-01T00:00:00Z","query":"what deadline is Priya Nair working toward","expectContains":["2026-08-15"],"hops":2},{"ts":"2026-03-01T00:00:00Z","query":"who owns the Atlas migration","expectContains":["Priya Nair"],"hops":1}]}
{"id":"service-owner-oncall","description":"Multi-hop: which team owns a service, and who is that team's on-call escalation.","events":[{"ts":"2026-02-10T11:00:00Z","content":"The checkout-gateway service is owned by the Payments team.","tags":["ownership","checkout"]},{"ts":"2026-02-11T11:00:00Z","content":"The Payments team on-call escalation goes to Marcus Feld via PagerDuty schedule PD-PAY.","tags":["oncall","payments"]}],"queries":[{"ts":"2026-04-20T00:00:00Z","query":"who do I escalate a checkout-gateway outage to","expectContains":["Marcus Feld"],"hops":2}]}
{"id":"lib-to-license","description":"Multi-hop: recall which library we chose for a task, then that library's license constraint.","events":[{"ts":"2026-03-02T13:00:00Z","content":"We standardized on the 'sharp' library for server-side image resizing.","tags":["decision","imaging"]},{"ts":"2026-03-04T13:00:00Z","content":"The sharp library is Apache-2.0 licensed, which legal already cleared for redistribution.","tags":["legal","license"]}],"queries":[{"ts":"2026-06-15T00:00:00Z","query":"is our image resizing library cleared for redistribution","expectContains":["Apache-2.0"],"hops":2}]}
{"id":"office-move","description":"Temporal supersession: office location changes; between-window query expects old, after query expects new and forbids the stale value.","events":[{"ts":"2026-01-10T09:00:00Z","content":"The engineering team office is in Building A, floor 3.","tags":["office","location"]},{"ts":"2026-03-15T09:00:00Z","content":"The engineering team office has moved to Building C, floor 7. Building A is no longer used by the team.","tags":["office","location"]}],"queries":[{"ts":"2026-02-01T00:00:00Z","query":"where is the engineering team office","expectContains":["Building A"],"expectAbsent":["Building C"],"hops":1},{"ts":"2026-04-01T00:00:00Z","query":"where is the engineering team office","expectContains":["Building C"],"expectAbsent":["Building A, floor 3"],"hops":1}]}
{"id":"tech-lead-handoff","description":"Temporal supersession of a role assignment across a handoff, plus a two-hop query after the change.","events":[{"ts":"2026-01-05T08:00:00Z","content":"Dana Cole is the tech lead of the Orion platform.","tags":["people","orion"]},{"ts":"2026-05-20T08:00:00Z","content":"Dana Cole moved to research; Sofia Reyes is now the tech lead of the Orion platform.","tags":["people","orion"]},{"ts":"2026-05-21T08:00:00Z","content":"The Orion platform is targeting a Q4 GA launch.","tags":["orion","roadmap"]}],"queries":[{"ts":"2026-02-15T00:00:00Z","query":"who is the tech lead of Orion","expectContains":["Dana Cole"],"expectAbsent":["Sofia Reyes"],"hops":1},{"ts":"2026-06-10T00:00:00Z","query":"who leads the platform targeting a Q4 GA launch","expectContains":["Sofia Reyes"],"expectAbsent":["Dana Cole is the tech lead"],"hops":2}]}
{"id":"deploy-target-migration","description":"Temporal supersession of infrastructure: deploy target moves from Heroku to AWS ECS.","events":[{"ts":"2026-02-01T10:00:00Z","content":"The analytics-api is deployed to Heroku in the eu-west region.","tags":["deploy","analytics"]},{"ts":"2026-06-12T10:00:00Z","content":"The analytics-api migrated off Heroku; it now runs on AWS ECS Fargate in eu-central-1.","tags":["deploy","analytics"]}],"queries":[{"ts":"2026-03-20T00:00:00Z","query":"where is the analytics-api deployed","expectContains":["Heroku"],"expectAbsent":["AWS ECS"],"hops":1},{"ts":"2026-07-01T00:00:00Z","query":"where is the analytics-api deployed","expectContains":["AWS ECS Fargate"],"expectAbsent":["Heroku"],"hops":1}]}
{"id":"pricing-tier-change","description":"Temporal supersession of a business fact: the Pro plan price is raised.","events":[{"ts":"2026-01-15T00:00:00Z","content":"The Pro plan is priced at $29 per seat per month.","tags":["pricing","plans"]},{"ts":"2026-04-01T00:00:00Z","content":"Effective April, the Pro plan price increased to $39 per seat per month.","tags":["pricing","plans"]}],"queries":[{"ts":"2026-02-20T00:00:00Z","query":"how much is the Pro plan per seat","expectContains":["$29"],"expectAbsent":["$39"],"hops":1},{"ts":"2026-05-01T00:00:00Z","query":"how much is the Pro plan per seat","expectContains":["$39"],"expectAbsent":["$29"],"hops":1}]}
{"id":"ci-provider-swap","description":"Temporal supersession of tooling: CI moves from CircleCI to GitHub Actions.","events":[{"ts":"2026-01-20T09:00:00Z","content":"Our CI runs on CircleCI; the config lives in .circleci/config.yml.","tags":["ci","tooling"]},{"ts":"2026-05-05T09:00:00Z","content":"We migrated CI to GitHub Actions; workflows are now under .github/workflows and CircleCI is decommissioned.","tags":["ci","tooling"]}],"queries":[{"ts":"2026-03-01T00:00:00Z","query":"what CI provider do we use","expectContains":["CircleCI"],"expectAbsent":["GitHub Actions"],"hops":1},{"ts":"2026-06-01T00:00:00Z","query":"what CI provider do we use","expectContains":["GitHub Actions"],"expectAbsent":["CircleCI"],"hops":1}]}
{"id":"standup-time-shift","description":"Temporal supersession of a recurring event time after a timezone reshuffle.","events":[{"ts":"2026-02-02T00:00:00Z","content":"The daily standup is at 9:30am Eastern.","tags":["meetings","schedule"]},{"ts":"2026-04-14T00:00:00Z","content":"Standup moved to 10:00am Eastern to accommodate the new London hires.","tags":["meetings","schedule"]}],"queries":[{"ts":"2026-03-10T00:00:00Z","query":"what time is the daily standup","expectContains":["9:30am"],"expectAbsent":["10:00am"],"hops":1},{"ts":"2026-05-20T00:00:00Z","query":"what time is the daily standup","expectContains":["10:00am"],"expectAbsent":["9:30am"],"hops":1}]}
{"id":"editor-preference","description":"Personal preference recall with a distractor about a colleague's differing preference.","events":[{"ts":"2026-01-12T18:00:00Z","content":"I prefer Neovim with the LazyVim distro for day-to-day editing.","tags":["preferences","tools"]},{"ts":"2026-01-13T18:00:00Z","content":"My teammate Jonah swears by VS Code, but that's his setup, not mine.","tags":["people","tools"]}],"queries":[{"ts":"2026-05-01T00:00:00Z","query":"what editor do I prefer","expectContains":["Neovim"],"expectAbsent":["VS Code"],"hops":1}]}
{"id":"coffee-order-distractor","description":"Distractor scenario: two similar people with similar orders; recall must not cross the wires.","events":[{"ts":"2026-02-05T08:15:00Z","content":"Sarah takes her coffee as an oat-milk flat white, no sugar.","tags":["people","preferences"]},{"ts":"2026-02-05T08:16:00Z","content":"Sara (different person, no H) drinks a double espresso, one sugar.","tags":["people","preferences"]}],"queries":[{"ts":"2026-06-01T00:00:00Z","query":"how does Sarah take her coffee","expectContains":["oat-milk flat white"],"expectAbsent":["double espresso"],"hops":1}]}
{"id":"env-var-distractor","description":"Distractor: similarly named config keys for staging vs production must not be confused.","events":[{"ts":"2026-03-01T12:00:00Z","content":"The production API base URL is set in API_BASE_URL_PROD = https://api.acme.com.","tags":["config","prod"]},{"ts":"2026-03-01T12:01:00Z","content":"The staging API base URL is set in API_BASE_URL_STAGING = https://staging.acme.internal.","tags":["config","staging"]}],"queries":[{"ts":"2026-05-15T00:00:00Z","query":"what is the production API base URL","expectContains":["api.acme.com"],"expectAbsent":["staging.acme.internal"],"hops":1}]}
