# cortexmd server configuration example.
# Copy to .env and adjust. Only API_KEY is strictly required.

# --- Required ---

# Bearer token clients must present (Authorization: Bearer <API_KEY>).
API_KEY=change-me

# --- Vaults ---

# The brain vault: the ONLY directory the server ever writes to.
# Defaults to a per-user data dir if unset:
#   Linux/macOS: $XDG_DATA_HOME/cortexmd/brain (or ~/.local/share/cortexmd/brain)
#   Windows:     %LOCALAPPDATA%\cortexmd\brain
# Created automatically on first boot.
BRAIN_VAULT=

# Read-only source vaults, comma-separated. Each entry is `name=path` (the name
# is a label) or a bare `path` (basename is used as the name). Defaults to empty.
#   Example: SOURCE_VAULTS=perso=/data/perso,work=/data/work-kb
SOURCE_VAULTS=

# --- Server ---

# HTTP listen port (default 3000).
API_PORT=3000

# Externally reachable base URL, used for OAuth metadata and links.
PUBLIC_URL=http://localhost:3000

# --- Features ---

# Embeddings / semantic search. Set to "false" to disable (default enabled).
ENABLE_EMBEDDINGS=true

# Reranker for search results. Set to "true" to enable (default disabled).
ENABLE_RERANKER=false

# Memory "dream" consolidation schedule (cron expression). Empty to disable.
DREAM_SCHEDULE=

# --- Deprecated (still honored for one release, with a warning) ---
# Prefer the new names above. These map onto BRAIN_VAULT / SOURCE_VAULTS.
#
# VAULT_RW=          # deprecated -> BRAIN_VAULT
# VAULT_RO_PERSO=    # deprecated -> SOURCE_VAULTS (append as a path)
# VAULT_RO_HAPLY=    # deprecated -> SOURCE_VAULTS (append as a path)
