{
  "name": "@cortexmd/server",
  "version": "1.0.0",
  "description": "cortexmd MCP server: code-nav, memory, and vault read/write operations",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/dashboard/assets','dist/dashboard/assets',{recursive:true})\"",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "hooks:install": "node scripts/install-hooks.mjs",
    "hooks:uninstall": "node scripts/install-hooks.mjs --uninstall",
    "code:index": "node bin/code-index.mjs",
    "contract:check": "node scripts/contract-check.mjs"
  },
  "bin": {
    "cortexmd-code-index": "bin/code-index.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@huggingface/transformers": "^3",
    "better-sqlite3": "^11.10.0",
    "express": "^5.1.0",
    "glob": "^11.0.2",
    "gray-matter": "^4.0.3",
    "hnswlib-node": "^3.0.0",
    "jose": "^6.2.2",
    "minisearch": "^7.1.2",
    "multer": "^2.1.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "^0.23.4",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.23.10",
    "tree-sitter-python": "^0.23.2",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.21",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
